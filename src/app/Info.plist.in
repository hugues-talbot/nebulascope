<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>                 <string>NebulaScope</string>
    <key>CFBundleDisplayName</key>          <string>NebulaScope</string>
    <key>CFBundleExecutable</key>           <string>${MACOSX_BUNDLE_EXECUTABLE_NAME}</string>
    <key>CFBundleIdentifier</key>           <string>org.nebulascope.app</string>
    <key>CFBundlePackageType</key>          <string>APPL</string>
    <key>CFBundleShortVersionString</key>   <string>1.0</string>
    <key>CFBundleVersion</key>              <string>1.0</string>
    <key>CFBundleIconFile</key>             <string>NebulaScope.icns</string>
    <key>NSHighResolutionCapable</key>      <true/>
    <key>LSMinimumSystemVersion</key>       <string>11.0</string>

    <!-- Document types this app can open (drives Finder "Open With" + defaults). -->
    <key>CFBundleDocumentTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeName</key>     <string>FITS image</string>
            <key>CFBundleTypeRole</key>     <string>Viewer</string>
            <key>LSItemContentTypes</key>   <array><string>org.nebulascope.fits</string></array>
        </dict>
        <dict>
            <key>CFBundleTypeName</key>     <string>XISF image</string>
            <key>CFBundleTypeRole</key>     <string>Viewer</string>
            <key>LSItemContentTypes</key>   <array><string>org.nebulascope.xisf</string></array>
        </dict>
        <dict>
            <key>CFBundleTypeName</key>     <string>Image</string>
            <key>CFBundleTypeRole</key>     <string>Viewer</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>public.jpeg</string>
                <string>public.png</string>
                <string>public.tiff</string>
            </array>
        </dict>
    </array>

    <!-- FITS and XISF have no system UTIs, so we declare them. -->
    <key>UTImportedTypeDeclarations</key>
    <array>
        <dict>
            <key>UTTypeIdentifier</key>     <string>org.nebulascope.fits</string>
            <key>UTTypeDescription</key>    <string>FITS image</string>
            <key>UTTypeConformsTo</key>     <array><string>public.data</string></array>
            <key>UTTypeTagSpecification</key>
            <dict>
                <key>public.filename-extension</key>
                <array><string>fits</string><string>fit</string><string>fts</string><string>fz</string></array>
            </dict>
        </dict>
        <dict>
            <key>UTTypeIdentifier</key>     <string>org.nebulascope.xisf</string>
            <key>UTTypeDescription</key>    <string>XISF image</string>
            <key>UTTypeConformsTo</key>     <array><string>public.data</string></array>
            <key>UTTypeTagSpecification</key>
            <dict>
                <key>public.filename-extension</key>
                <array><string>xisf</string></array>
            </dict>
        </dict>
    </array>
</dict>
</plist>
